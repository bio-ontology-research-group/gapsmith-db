# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# Python
python/.venv
python/.pytest_cache
python/.ruff_cache
python/dist
python/build
python/*.egg-info
__pycache__
*.pyc

# Raw upstream data — only SOURCE.toml is committed; artefacts are fetched.
data/*/*
!data/*/SOURCE.toml
!data/*/.gitkeep
!data/README.md
data/*/.tmp
data/*/MANIFEST.json

# Proposals, curator state, LLM cache. Hand-authored fixtures under
# proposals/fixtures/ are committed (the mock proposer and CI depend
# on them); the pathway-name catalogue under proposals/catalogue/ is
# also committed (seed list for the batch proposer). The rest of
# proposals/ (pending/, for_curation/, rejected/, decisions.log.jsonl)
# is runtime state.
proposals/*
!proposals/fixtures/
!proposals/catalogue/
corpus/
.cache/
.openrouter/
*.env.local

# Editor / OS
*.swp
*.swo
.DS_Store
.idea/
.vscode/

# Backups
*~
